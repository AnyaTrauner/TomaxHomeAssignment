# Copy this file to .env and fill in the values. NEVER commit .env to source control.

NODE_ENV=development

PORT=3000

# ---- Local Docker development (matches docker-compose.yml) ----
DB_HOST=127.0.0.1
DB_USER=invoices_user
DB_PASSWORD=invoices_pass
DB_NAME=invoices_db

# ---- Production (fill in real values, never commit) ----
# DB_HOST=db.internal
# DB_USER=admin
# DB_PASSWORD=
# DB_NAME=invoices_db

# Secret used to sign and verify JWT tokens. Use a long random string (32+ chars).
JWT_SECRET=
