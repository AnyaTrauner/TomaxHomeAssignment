# Copy this file to .env and fill in the values. NEVER commit .env to source control.

NODE_ENV=development

PORT=3000

# DB provider selection:
# - sqlite (recommended for local dev and tests)
# - mysql  (recommended for production)
# If omitted, defaults to sqlite except when NODE_ENV=production (then mysql).
DB_PROVIDER=sqlite

# SQLite local database file path
SQLITE_PATH=./tests/data/invoices.sqlite

# MySQL (typically production)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Secret used to sign and verify JWT tokens. Use a long random string (32+ chars).
JWT_SECRET=
